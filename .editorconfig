root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{java}]
indent_style = tab
tab_width = 4

[*.json]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{md,txt}]
trim_trailing_whitespace = false

[*.properties]
indent_style = space
indent_size = 2

[*.gradle]
indent_style = tab
tab_width = 4

[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf
